# GPT image generation
GPT_IMAGE_API_KEY=
GPT_IMAGE_API_URL=https://www.right.codes/draw
# GPT_IMAGE_MODEL=gpt-image-2-pro
# GPT_IMAGE_API_MODE=images
# Set GPT_IMAGE_API_MODE=chat only for legacy /v1/chat/completions image gateways.
# GPT_IMAGE_GROUP=vip_2_image

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# NAS deployment (used by ./deploy-to-nas.sh)
NAS_HOST=
NAS_USER=
NAS_PATH=/volume1/docker/my-site
NAS_PASSWORD=
# NAS_PACKAGE_FILE=my-site-deploy.tar.gz
# NAS_IMAGE_NAME=my-site:latest
# NAS_CLAUDE_WORKER_IMAGE_NAME=my-site-claude-worker:latest
# NAS_COMPOSE_FILE=docker-compose.nas.yml
# NAS_ENV_FILE=.env.local
# NAS_REMOTE_STAGE_BASE=/volume1/docker/my-site/.codex-deploy-stage
# CONTAINER_LOG_MAX_SIZE=10m
# CONTAINER_LOG_MAX_FILES=5

# X / Twitter API (https://developer.x.com)
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
