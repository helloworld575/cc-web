# Auth
ADMIN_PASSWORD=   # set a strong password; "changeme" is blocked in production
NEXTAUTH_SECRET=   # generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Claude AI (get your key from https://console.anthropic.com)
CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_API_HOST=https://api.anthropic.com

# GPT image generation
GPT_IMAGE_API_KEY=
GPT_IMAGE_API_URL=https://right.codes
# GPT_IMAGE_MODEL=gpt-image-2-pro
# GPT_IMAGE_GROUP=vip_2_image

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# NAS deployment (used by ./deploy-to-nas.sh)
NAS_HOST=
NAS_USER=
NAS_PATH=/volume1/docker/my-site
NAS_PASSWORD=
# NAS_PACKAGE_FILE=my-site-deploy.tar.gz
# NAS_IMAGE_NAME=my-site:latest
# NAS_COMPOSE_FILE=docker-compose.nas.yml
# NAS_ENV_FILE=.env.local
# NAS_REMOTE_STAGE_BASE=/volume1/docker/my-site/.codex-deploy-stage

# X / Twitter API (https://developer.x.com)
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
