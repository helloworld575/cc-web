{
  "name": "my-site",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:managed": "node scripts/run-managed-command.mjs --label next-dev --clear-port 3000 -- node ./node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "next start",
    "lint": "npm run lint:format && npm run lint:architecture && npm run typecheck",
    "lint:architecture": "node scripts/check-architecture.mjs",
    "lint:format": "node scripts/check-format.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:api": "vitest run tests/api",
    "test:lib": "vitest run tests/lib tests/config",
    "test:managed": "node scripts/run-managed-command.mjs --label vitest -- node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "vitest",
    "e2e": "node scripts/run-managed-command.mjs --label playwright-e2e --clear-port 3001 -- node ./node_modules/playwright/cli.js test",
    "e2e:headed": "node scripts/run-managed-command.mjs --label playwright-e2e-headed --clear-port 3001 -- node ./node_modules/playwright/cli.js test --headed",
    "run:managed": "node scripts/run-managed-command.mjs",
    "codex:skills": "node scripts/normalize-codex-skills.mjs",
    "codex:cache": "node scripts/refresh-codex-cache.mjs",
    "verify": "npm run lint && npm test && npm run build",
    "verify:large": "npm run verify && npm run e2e"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@toast-ui/editor": "^3.2.2",
    "better-sqlite3": "12.8.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.10",
    "next-auth": "^4.24.14",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "dompurify": "^3.4.11",
    "js-yaml": "^3.15.0",
    "postcss": "^8.5.16",
    "uuid": "^11.1.1"
  }
}
